{
  "$schema": "sinomedia-page-spec/v1",
  "route": "/dash/home",
  "title": "Tổng quan hệ thống",
  "titleEn": "System Overview",
  "priority": "P0",
  "minRole": "viewer",
  "layout": {
    "type": "dashboard",
    "sidebar": true,
    "header": true,
    "padding": "px-4 md:px-8 py-6",
    "maxWidth": "max-w-[1400px]"
  },
  "header": {
    "breadcrumb": ["SinoMedia", "Tổng quan"],
    "title": "Tổng quan hệ thống",
    "titleEn": "System Overview",
    "actions": []
  },
  "sections": [
    {
      "id": "metric-banner",
      "type": "metric-cards-row",
      "description": "Hàng card số liệu nhanh – hiển thị tổng số liệu toàn hệ thống",
      "layout": "grid-4",
      "cards": [
        {
          "id": "total-posts",
          "label": "Bài viết đã cào",
          "labelEn": "Posts Crawled",
          "icon": "DocumentTextIcon",
          "color": "blue",
          "dataSource": {
            "table": "crawled_posts",
            "query": "COUNT(*)"
          },
          "trend": true,
          "trendPeriod": "7d"
        },
        {
          "id": "total-authors",
          "label": "Tác giả / KOL",
          "labelEn": "Authors / KOL",
          "icon": "UsersIcon",
          "color": "violet",
          "dataSource": {
            "table": "crawled_authors",
            "query": "COUNT(*)"
          },
          "trend": true,
          "trendPeriod": "7d"
        },
        {
          "id": "running-tasks",
          "label": "Task đang chạy",
          "labelEn": "Running Tasks",
          "icon": "PlayCircleIcon",
          "color": "emerald",
          "dataSource": {
            "table": "crawler_tasks",
            "query": "COUNT(*) WHERE status IN ('running','pending')"
          },
          "trend": false
        },
        {
          "id": "account-health",
          "label": "Tài khoản hoạt động",
          "labelEn": "Active Accounts",
          "icon": "KeyIcon",
          "color": "orange",
          "dataSource": {
            "table": "crawler_accounts",
            "query": "COUNT(*) WHERE status = 'active' / COUNT(*) total"
          },
          "format": "ratio",
          "badgeOnLow": { "threshold": 0.3, "color": "red", "label": "Cảnh báo" }
        }
      ]
    },
    {
      "id": "charts-row",
      "type": "charts-grid",
      "description": "Biểu đồ phân tích xu hướng và phân bổ dữ liệu",
      "layout": "grid-3",
      "charts": [
        {
          "id": "posts-growth-chart",
          "type": "line-chart",
          "title": "Bài viết cào mới theo ngày",
          "titleEn": "New Posts Per Day",
          "span": 2,
          "dataSource": {
            "table": "crawled_posts",
            "groupBy": "DATE(crawled_at)",
            "period": "7d"
          },
          "xAxis": "date",
          "yAxis": "count",
          "color": "blue",
          "showDots": true,
          "showGrid": true
        },
        {
          "id": "platform-distribution-chart",
          "type": "donut-chart",
          "title": "Phân bổ theo nền tảng",
          "titleEn": "Distribution by Platform",
          "span": 1,
          "dataSource": {
            "table": "crawled_posts",
            "groupBy": "platform",
            "query": "COUNT(*)"
          },
          "colors": {
            "douyin": "#FE2C55",
            "xhs": "#FF2442",
            "bilibili": "#00A1D6",
            "weibo": "#E6162D",
            "kuaishou": "#FF4906",
            "tieba": "#1678FF",
            "zhihu": "#0066FF",
            "tiktok": "#000000"
          },
          "showLegend": true
        }
      ]
    },
    {
      "id": "platform-health",
      "type": "platform-health-cards",
      "description": "Card sức khỏe pool tài khoản theo từng nền tảng",
      "title": "Sức khỏe Pool Cookie",
      "titleEn": "Cookie Pool Health",
      "layout": "grid-4",
      "platforms": ["douyin", "xhs", "bilibili", "weibo", "kuaishou", "tieba", "zhihu", "tiktok"],
      "dataSource": {
        "table": "crawler_accounts",
        "groupBy": "platform",
        "fields": ["status"]
      },
      "card": {
        "showActive": true,
        "showBanned": true,
        "statusThresholds": {
          "healthy": { "minActiveRatio": 0.6, "color": "emerald", "label": "Bình thường" },
          "warning": { "minActiveRatio": 0.3, "color": "amber", "label": "Cảnh báo" },
          "critical": { "minActiveRatio": 0.0, "color": "red", "label": "Nguy hiểm" }
        },
        "clickAction": { "navigate": "/dash/accounts", "filterParam": "platform" }
      }
    },
    {
      "id": "recent-tasks",
      "type": "recent-tasks-feed",
      "description": "Danh sách 5 task cào gần nhất và trạng thái thực thi",
      "title": "Hoạt động gần đây",
      "titleEn": "Recent Activity",
      "limit": 5,
      "dataSource": {
        "table": "crawler_tasks",
        "orderBy": "created_at DESC",
        "fields": ["id", "platform", "command", "target", "status", "created_at", "created_by"]
      },
      "columns": [
        { "key": "platform", "label": "Nền tảng", "type": "platform-badge" },
        { "key": "command", "label": "Loại cào", "type": "text" },
        { "key": "target", "label": "Target", "type": "text-truncate", "maxWidth": 200 },
        { "key": "status", "label": "Trạng thái", "type": "status-badge" },
        { "key": "created_at", "label": "Thời gian", "type": "relative-time" }
      ],
      "rowAction": { "type": "open-console", "param": "task_id" },
      "footer": { "label": "Xem tất cả nhiệm vụ", "href": "/dash/tasks" }
    }
  ]
}
