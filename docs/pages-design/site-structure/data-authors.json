{
  "$schema": "sinomedia-page-spec/v1",
  "route": "/dash/data/authors",
  "title": "Khám phá Tác giả / KOL",
  "titleEn": "Authors Explorer",
  "priority": "P1",
  "minRole": "viewer",
  "layout": { "type": "dashboard", "sidebar": true, "header": true, "padding": "px-4 md:px-8 py-6", "maxWidth": "max-w-[1400px]" },
  "header": {
    "breadcrumb": ["SinoMedia", "Data Explorer", "Tác giả"],
    "title": "Khám phá Tác giả / KOL",
    "actions": [
      { "id": "export-btn", "label": "Xuất Excel", "type": "button", "variant": "outline", "icon": "ArrowDownTrayIcon", "action": "export-authors-excel" }
    ]
  },
  "filterBar": {
    "position": "top",
    "layout": "horizontal",
    "filterPayload": "json-to-backend",
    "filters": [
      { "id": "search", "type": "search-input", "placeholder": "Tìm theo tên, UID, mô tả...", "fields": ["nickname","platform_uid","description"] },
      { "id": "platform", "type": "multi-select-checkbox", "label": "Nền tảng", "field": "platform", "options": ["douyin","xhs","bilibili","weibo","kuaishou","tieba","zhihu","tiktok"] },
      { "id": "ip_location", "type": "select", "label": "IP Location", "field": "ip_location", "loadFrom": "distinct:crawled_authors.ip_location" },
      { "id": "fans_min", "type": "number", "label": "Fans tối thiểu", "field": "fans_count", "operator": "gte", "placeholder": "VD: 10000" },
      { "id": "fans_max", "type": "number", "label": "Fans tối đa", "field": "fans_count", "operator": "lte", "placeholder": "VD: 1000000" }
    ]
  },
  "sections": [
    {
      "id": "authors-grid",
      "type": "data-table-with-filters",
      "dataSource": {
        "table": "crawled_authors",
        "orderBy": [{ "field": "fans_count", "direction": "DESC" }],
        "fields": ["id","platform_uid","nickname","platform","gender","description","fans_count","follows_count","ip_location","avatar_url","crawled_at"]
      },
      "viewModes": ["table", "grid"],
      "defaultView": "table",
      "columns": [
        { "key": "avatar_url", "label": "", "type": "avatar", "width": 40, "source": "r2" },
        { "key": "nickname", "label": "Tên tác giả", "type": "text-bold-with-sub", "subKey": "platform_uid" },
        { "key": "platform", "label": "Nền tảng", "type": "platform-badge" },
        { "key": "gender", "label": "Giới tính", "type": "gender-badge", "width": 80 },
        { "key": "fans_count", "label": "Fans", "type": "number-formatted" },
        { "key": "follows_count", "label": "Đang follow", "type": "number-formatted" },
        { "key": "ip_location", "label": "IP Location", "type": "text" },
        { "key": "crawled_at", "label": "Cào lúc", "type": "relative-time" },
        {
          "key": "actions", "label": "", "type": "action-menu",
          "actions": [
            { "id": "view-posts", "label": "Xem bài viết", "icon": "DocumentTextIcon", "action": "navigate", "href": "/dash/data/posts?author_id={id}" }
          ]
        }
      ],
      "rowClick": { "action": "navigate", "href": "/dash/data/posts?author_uid={platform_uid}&platform={platform}" },
      "emptyState": { "icon": "UsersIcon", "title": "Chưa có tác giả nào", "description": "Chạy task cào Creator để thu thập dữ liệu KOL" },
      "pagination": { "pageSize": 30, "showTotal": true }
    }
  ]
}
