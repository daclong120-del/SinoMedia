{
  "$meta": {
    "domain": "style",
    "source": "init-fontend/design-system/*.json",
    "extractedFrom": "tokens-consolidation",
    "purpose": "Consolidated design tokens style guide for unified code generation"
  },
  "colors": {
    "brand": {
      "primary": {
        "light": "rgb(0, 81, 195)",
        "dark": "oklch(0.922 0 0)"
      },
      "orange": "rgb(246, 130, 31)"
    },
    "backgrounds": {
      "canvas": {
        "light": "oklch(0.9875 0 0)",
        "dark": "oklch(0.145 0 0)"
      },
      "card": {
        "light": "#ffffff",
        "dark": "oklch(0.205 0 0)"
      },
      "popover": {
        "light": "#ffffff",
        "dark": "oklch(0.205 0 0)"
      },
      "secondary": {
        "light": "oklch(0.97 0 0)",
        "dark": "oklch(0.269 0 0)"
      },
      "muted": {
        "light": "oklch(0.97 0 0)",
        "dark": "oklch(0.269 0 0)"
      }
    },
    "borders": {
      "border": {
        "light": "oklch(0.145 0 0 / 0.1)",
        "dark": "oklch(1 0 0 / 10%)"
      },
      "input": {
        "light": "oklch(0.145 0 0 / 0.1)",
        "dark": "oklch(1 0 0 / 15%)"
      }
    },
    "text": {
      "foreground": {
        "light": "rgb(49, 49, 49)",
        "dark": "oklch(0.985 0 0)"
      },
      "primaryForeground": {
        "light": "#ffffff",
        "dark": "oklch(0.205 0 0)"
      },
      "mutedForeground": {
        "light": "oklch(0.556 0 0)",
        "dark": "oklch(0.708 0 0)"
      },
      "accentForeground": {
        "light": "rgb(0, 81, 195)",
        "dark": "oklch(0.985 0 0)"
      }
    }
  },
  "typography": {
    "fonts": {
      "sans": "\"Inter Variable\", \"Inter\", ui-sans-serif, system-ui, sans-serif",
      "mono": "\"Geist Mono\", \"Geist Mono Fallback\", ui-monospace, monospace"
    },
    "sizes": {
      "9px": {
        "size": "9px",
        "lineHeight": "12px"
      },
      "10px": {
        "size": "10px",
        "lineHeight": "14px"
      },
      "xs": {
        "size": "12px",
        "lineHeight": "16px"
      },
      "sm": {
        "size": "14px",
        "lineHeight": "20px"
      },
      "base": {
        "size": "16px",
        "lineHeight": "24px"
      },
      "lg": {
        "size": "18px",
        "lineHeight": "28px"
      },
      "xl": {
        "size": "20px",
        "lineHeight": "28px"
      },
      "2xl": {
        "size": "24px",
        "lineHeight": "32px"
      },
      "3xl": {
        "size": "30px",
        "lineHeight": "36px"
      }
    }
  },
  "radius": {
    "base": "0.625rem",
    "sm": "calc(var(--radius) * 0.6)",
    "md": "calc(var(--radius) * 0.8)",
    "lg": "var(--radius)",
    "xl": "calc(var(--radius) * 1.4)",
    "2xl": "calc(var(--radius) * 1.8)",
    "3xl": "calc(var(--radius) * 2.2)",
    "4xl": "calc(var(--radius) * 2.6)"
  },
  "spacing": {
    "p-1.5": "6px",
    "p-2": "8px",
    "p-2.5": "10px",
    "p-3": "12px",
    "p-5": "20px",
    "p-6": "24px",
    "p-8": "32px",
    "p-10": "40px"
  },
  "motion": {
    "durations": {
      "fast": "150ms",
      "normal": "200ms",
      "slow": "300ms"
    },
    "easings": {
      "default": "ease-in-out",
      "in": "ease-in",
      "out": "ease-out"
    }
  }
}
