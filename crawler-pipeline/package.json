{
  "name": "crawler-pipeline",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "crawl": "tsx src/index.ts crawl",
    "worker:dev": "nodemon --watch src --exec tsx src/index.ts crawl",
    "creator": "tsx src/index.ts creator",
    "search": "tsx src/index.ts search",
    "comments": "tsx src/index.ts comments",
    "add-account": "tsx src/index.ts add-account",
    "refresh": "tsx src/index.ts refresh"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "impit": "^0.14.2",
    "undici": "^6.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
