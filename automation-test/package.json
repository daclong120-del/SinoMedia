{
  "name": "sinomedia-automation-test",
  "version": "1.0.0",
  "description": "Automation test framework for SinoMedia using Playwright TS",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:all": "playwright test",
    "test:ui": "playwright test --grep @ui",
    "test:backend": "playwright test --grep @backend",
    "test:module": "node runner/run-module.js",
    "dashboard": "node runner/server.js",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "playwright",
    "automation",
    "test",
    "sinomedia"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/node": "^20.11.0",
    "dotenv": "^16.4.5",
    "typescript": "^5.4.5"
  }
}
