{
  "$schema": "sinomedia-page-spec/v1",
  "route": "/dash/settings/permissions",
  "title": "Phân quyền Viewer",
  "titleEn": "Viewer Permissions",
  "priority": "P1",
  "minRole": "admin",
  "layout": { "type": "dashboard", "sidebar": true, "header": true, "padding": "px-4 md:px-8 py-6", "maxWidth": "max-w-[900px]" },
  "header": {
    "breadcrumb": ["SinoMedia", "Admin", "Cài đặt", "Phân quyền"],
    "title": "Phân quyền Viewer",
    "description": "Kiểm soát chính xác Viewer được phép thấy và làm gì. Tính năng bị tắt sẽ ẩn hoàn toàn khỏi Sidebar."
  },
  "sections": [
    {
      "id": "permission-matrix",
      "type": "permission-matrix",
      "dataSource": { "table": "viewer_permissions" },
      "saveAction": "save-viewer-permissions",
      "note": "Thay đổi có hiệu lực ngay với tất cả tài khoản Viewer. Admin luôn có toàn quyền và không bị ảnh hưởng bởi bảng này.",
      "groups": [
        {
          "id": "dashboard",
          "label": "Dashboard",
          "permissions": [
            { "key": "view_overview", "label": "Xem trang Tổng quan", "default": true, "locked": false }
          ]
        },
        {
          "id": "crawler-controller",
          "label": "Crawler Controller",
          "permissions": [
            { "key": "view_tasks", "label": "Xem danh sách Tasks", "default": true },
            { "key": "create_task_immediate", "label": "Tạo Task – Chạy ngay", "default": false, "lockedOff": true, "note": "Luôn tắt với Viewer" },
            { "key": "create_task_scheduled", "label": "Tạo Task – Lên lịch tương lai", "default": true },
            { "key": "view_console_logs", "label": "Xem Console Logs", "default": true },
            { "key": "view_accounts", "label": "Xem trang Accounts", "default": false },
            { "key": "view_proxies", "label": "Xem trang Proxy Pool", "default": false }
          ]
        },
        {
          "id": "data-explorer",
          "label": "Data Explorer",
          "permissions": [
            { "key": "view_authors", "label": "Xem trang Tác giả", "default": true },
            { "key": "view_posts", "label": "Xem trang Bài viết & Video", "default": true },
            { "key": "export_data", "label": "Xuất Excel / CSV", "default": true },
            { "key": "tag_posts", "label": "Gắn nhãn bài viết", "default": false },
            { "key": "delete_posts", "label": "Xóa bài viết", "default": false, "lockedOff": true },
            { "key": "view_data_management", "label": "Xem trang Quản lý dữ liệu", "default": false }
          ]
        },
        {
          "id": "admin",
          "label": "Admin (Luôn ẩn với Viewer)",
          "note": "Các mục này luôn chỉ dành cho Admin, không thể thay đổi",
          "permissions": [
            { "key": "view_audit_logs", "label": "Xem Audit Logs", "default": false, "locked": true },
            { "key": "view_settings", "label": "Xem Cài đặt hệ thống", "default": false, "locked": true },
            { "key": "view_permissions", "label": "Xem Phân quyền", "default": false, "locked": true }
          ]
        }
      ]
    }
  ]
}
