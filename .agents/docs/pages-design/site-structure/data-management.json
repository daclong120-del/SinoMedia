{
  "$schema": "sinomedia-page-spec/v1",
  "route": "/dash/data/management",
  "title": "Quản lý dữ liệu cấp cao",
  "titleEn": "Data Management",
  "priority": "P1",
  "minRole": "admin",
  "layout": { "type": "dashboard", "sidebar": true, "header": true, "padding": "px-4 md:px-8 py-6", "maxWidth": "max-w-[1400px]" },
  "header": {
    "breadcrumb": ["SinoMedia", "Data Explorer", "Quản lý dữ liệu"],
    "title": "Quản lý dữ liệu cấp cao"
  },
  "sections": [
    {
      "id": "storage-monitor",
      "type": "stats-storage-monitor",
      "title": "Giám sát dung lượng",
      "layout": "grid-2",
      "cards": [
        {
          "id": "supabase-db",
          "label": "Supabase Database",
          "icon": "CircleStackIcon",
          "color": "blue",
          "dataSource": { "api": "supabase-storage-stats" },
          "showBar": true,
          "fields": [
            { "key": "crawled_posts", "label": "Bài viết (rows)" },
            { "key": "crawled_comments", "label": "Bình luận (rows)" },
            { "key": "crawled_authors", "label": "Tác giả (rows)" },
            { "key": "crawler_tasks", "label": "Tasks (rows)" }
          ]
        },
        {
          "id": "cloudflare-r2",
          "label": "Cloudflare R2 Storage",
          "icon": "CloudIcon",
          "color": "orange",
          "dataSource": { "api": "r2-bucket-stats" },
          "showBar": true,
          "format": "file-size",
          "fields": [
            { "key": "total_size", "label": "Tổng dung lượng" },
            { "key": "video_count", "label": "Số file video" },
            { "key": "image_count", "label": "Số file ảnh" }
          ]
        }
      ],
      "note": "Media lưu trữ vĩnh viễn trên R2 (không auto-delete). Dọn dẹp thủ công tại mục bên dưới."
    },
    {
      "id": "cleanup-tools",
      "type": "action-cards-group",
      "title": "Dọn dẹp dữ liệu",
      "titleEn": "Data Clean-up Tools",
      "layout": "grid-3",
      "actions": [
        {
          "id": "delete-old-posts",
          "label": "Xóa bài viết cũ hơn X ngày",
          "icon": "CalendarDaysIcon",
          "color": "amber",
          "params": [{ "id": "days", "label": "Số ngày", "type": "number", "defaultValue": 30 }],
          "confirmText": "Xóa tất cả bài viết cào được trước {days} ngày?",
          "action": "cleanup-old-posts"
        },
        {
          "id": "delete-zero-engagement",
          "label": "Xóa bài viết không có tương tác",
          "icon": "MinusCircleIcon",
          "color": "amber",
          "description": "Xóa bài có like=0, view=0, comment=0",
          "confirmText": "Xóa tất cả bài viết không có tương tác?",
          "action": "cleanup-zero-engagement"
        },
        {
          "id": "cleanup-r2-orphans",
          "label": "Giải phóng file R2 không dùng",
          "icon": "TrashIcon",
          "color": "red",
          "description": "Xóa file media trên R2 không còn liên kết với bài viết nào trong DB",
          "confirmText": "Thao tác này sẽ xóa file media khỏi R2. Không thể hoàn tác. Tiếp tục?",
          "action": "cleanup-r2-orphans",
          "requireExtraConfirm": true
        }
      ]
    },
    {
      "id": "exported-files-history",
      "type": "data-table-with-filters",
      "title": "Lịch sử file xuất (Export History)",
      "dataSource": {
        "table": "exported_files",
        "orderBy": [{ "field": "created_at", "direction": "DESC" }],
        "fields": ["id","filename","type","filter_snapshot","size_bytes","created_by","created_at","download_url"]
      },
      "columns": [
        { "key": "filename", "label": "Tên file", "type": "text-bold" },
        { "key": "type", "label": "Loại", "type": "badge" },
        { "key": "size_bytes", "label": "Kích thước", "type": "file-size" },
        { "key": "created_by", "label": "Xuất bởi", "type": "text" },
        { "key": "created_at", "label": "Thời gian", "type": "relative-time" },
        {
          "key": "actions", "label": "", "type": "action-menu",
          "actions": [
            { "id": "download", "label": "Tải về", "icon": "ArrowDownTrayIcon", "action": "download-exported-file" },
            { "id": "view-filter", "label": "Xem filter đã dùng", "icon": "FunnelIcon", "action": "show-filter-snapshot" },
            { "id": "delete", "label": "Xóa", "variant": "destructive", "action": "delete-exported-file" }
          ]
        }
      ],
      "pagination": { "pageSize": 20 }
    },
    {
      "id": "tag-manager",
      "type": "crud-list",
      "title": "Quản lý nhãn (Tag Manager)",
      "dataSource": { "table": "post_tags", "orderBy": [{ "field": "created_at", "direction": "DESC" }] },
      "addForm": {
        "fields": [
          { "id": "name", "label": "Tên nhãn", "type": "text", "required": true },
          { "id": "color", "label": "Màu", "type": "color-picker", "defaultValue": "#3b82f6" },
          { "id": "description", "label": "Mô tả", "type": "text" }
        ]
      },
      "listColumns": [
        { "key": "color", "label": "", "type": "color-dot", "width": 30 },
        { "key": "name", "label": "Tên nhãn", "type": "text-bold" },
        { "key": "description", "label": "Mô tả", "type": "text" },
        { "key": "usage_count", "label": "Đã dùng", "type": "number" },
        {
          "key": "actions", "label": "", "type": "action-menu",
          "actions": [
            { "id": "edit", "label": "Sửa", "icon": "PencilIcon", "action": "edit-tag" },
            { "id": "delete", "label": "Xóa", "variant": "destructive", "action": "delete-tag", "confirmText": "Xóa nhãn này? Tất cả bài viết dùng nhãn này sẽ bị xóa nhãn." }
          ]
        }
      ]
    }
  ]
}
