{
  "$schema": "sinomedia-page-spec/v1",
  "route": "/dash/tasks",
  "title": "Chiến dịch & Nhiệm vụ cào",
  "titleEn": "Crawl Tasks",
  "priority": "P0",
  "minRole": "viewer",
  "layout": {
    "type": "dashboard",
    "sidebar": true,
    "header": true,
    "padding": "px-4 md:px-8 py-6",
    "maxWidth": "max-w-[1400px]"
  },
  "header": {
    "breadcrumb": ["SinoMedia", "Crawler Controller", "Nhiệm vụ cào"],
    "title": "Chiến dịch & Nhiệm vụ cào",
    "titleEn": "Crawl Tasks",
    "actions": [
      {
        "id": "create-task-btn",
        "label": "Tạo nhiệm vụ mới",
        "labelEn": "New Task",
        "type": "button",
        "variant": "primary",
        "icon": "PlusIcon",
        "role": "admin",
        "action": "open-create-task-modal"
      }
    ]
  },
  "sections": [
    {
      "id": "create-task-modal",
      "type": "modal-form",
      "trigger": "create-task-btn",
      "title": "Tạo nhiệm vụ cào mới",
      "titleEn": "Create New Crawl Task",
      "width": "max-w-2xl",
      "role": "admin",
      "formGroups": [
        {
          "id": "target-config",
          "title": "Cấu hình mục tiêu",
          "titleEn": "Target Configuration",
          "fields": [
            {
              "id": "platform",
              "label": "Nền tảng",
              "labelEn": "Platform",
              "type": "select",
              "required": true,
              "options": [
                { "value": "douyin", "label": "Douyin (抖音)" },
                { "value": "xhs", "label": "XHS / Tiểu Hồng Thư" },
                { "value": "bilibili", "label": "Bilibili (哔哩哔哩)" },
                { "value": "weibo", "label": "Weibo (微博)" },
                { "value": "kuaishou", "label": "Kuaishou (快手)" },
                { "value": "tieba", "label": "Tieba (贴吧)" },
                { "value": "zhihu", "label": "Zhihu (知乎)" },
                { "value": "tiktok", "label": "TikTok" }
              ]
            },
            {
              "id": "command",
              "label": "Danh mục cào",
              "labelEn": "Crawl Command",
              "type": "select",
              "required": true,
              "options": [
                { "value": "creator", "label": "Cào Creator (KOL/Tác giả)" },
                { "value": "search", "label": "Cào Search (Từ khóa)" },
                { "value": "comment", "label": "Cào Comment (Bình luận)" },
                { "value": "ads", "label": "Cào Ads Target (Quảng cáo đối thủ)" }
              ]
            },
            {
              "id": "targets",
              "label": "Target / Từ khóa",
              "labelEn": "Targets / Keywords",
              "type": "textarea",
              "required": true,
              "placeholder": "Nhập mỗi target một dòng\nVí dụ:\nuid_123456\nkem chống nắng\nhttps://...",
              "helpText": "Hỗ trợ nhập hàng loạt, mỗi dòng một target",
              "rows": 5
            },
            {
              "id": "start_page",
              "label": "Trang bắt đầu (Offset)",
              "labelEn": "Start Page / Offset",
              "type": "number",
              "defaultValue": 1,
              "min": 1,
              "helpText": "Bỏ qua bao nhiêu trang đầu. Mặc định = 1 (bắt đầu từ đầu)"
            },
            {
              "id": "max_count",
              "label": "Số lượng tối đa",
              "labelEn": "Max Count",
              "type": "number",
              "defaultValue": 50,
              "min": 1,
              "max": 10000
            },
            {
              "id": "comment_depth",
              "label": "Độ sâu bình luận",
              "labelEn": "Comment Depth",
              "type": "number",
              "defaultValue": 2,
              "min": 1,
              "max": 5,
              "helpText": "Số cấp bình luận lồng nhau cần cào (1-5)",
              "showWhen": { "field": "command", "equals": "comment" }
            }
          ]
        },
        {
          "id": "output-config",
          "title": "Cấu hình đầu ra",
          "titleEn": "Output Configuration",
          "fields": [
            {
              "id": "download_media",
              "label": "Tải Media về R2",
              "labelEn": "Download Media to R2",
              "type": "checkbox",
              "defaultValue": false,
              "helpText": "Tải video/ảnh gốc lên Cloudflare R2. Tắt = chỉ lưu text/metadata"
            },
            {
              "id": "min_likes",
              "label": "Like tối thiểu",
              "labelEn": "Minimum Likes",
              "type": "number",
              "defaultValue": 0,
              "min": 0,
              "helpText": "Chỉ lưu bài viết có Like ≥ giá trị này"
            },
            {
              "id": "published_after",
              "label": "Chỉ lấy bài đăng sau ngày",
              "labelEn": "Published After",
              "type": "date",
              "helpText": "Lọc theo ngày đăng bài viết"
            },
            {
              "id": "webhook_url",
              "label": "Webhook thông báo (tùy chọn)",
              "labelEn": "Notification Webhook",
              "type": "url",
              "placeholder": "https://hooks.slack.com/... hoặc Telegram webhook",
              "helpText": "Nhận thông báo khi task hoàn thành"
            }
          ]
        },
        {
          "id": "schedule-config",
          "title": "Lên lịch & Ưu tiên",
          "titleEn": "Schedule & Priority",
          "fields": [
            {
              "id": "run_mode",
              "label": "Chế độ chạy",
              "labelEn": "Run Mode",
              "type": "radio",
              "options": [
                { "value": "immediate", "label": "Chạy ngay", "role": "admin" },
                { "value": "scheduled", "label": "Lên lịch (Viewer cũng dùng được)" }
              ],
              "defaultValue": "scheduled"
            },
            {
              "id": "scheduled_at",
              "label": "Thời gian thực thi",
              "labelEn": "Scheduled Time",
              "type": "datetime-local",
              "showWhen": { "field": "run_mode", "equals": "scheduled" }
            },
            {
              "id": "priority",
              "label": "Mức ưu tiên",
              "labelEn": "Priority",
              "type": "select",
              "defaultValue": "normal",
              "options": [
                { "value": "critical", "label": "Critical – Chạy trước tất cả" },
                { "value": "high", "label": "High – Ưu tiên cao" },
                { "value": "normal", "label": "Normal – Mặc định" },
                { "value": "low", "label": "Low – Chạy sau cùng" }
              ]
            }
          ]
        }
      ],
      "actions": [
        { "id": "cancel", "label": "Hủy", "type": "button", "variant": "outline", "action": "close-modal" },
        { "id": "submit", "label": "Tạo nhiệm vụ", "type": "submit", "variant": "primary" }
      ]
    },
    {
      "id": "task-queue",
      "type": "data-table-with-filters",
      "title": "Hàng đợi nhiệm vụ",
      "titleEn": "Task Queue",
      "dataSource": {
        "table": "crawler_tasks",
        "orderBy": [
          { "field": "priority_order", "direction": "ASC" },
          { "field": "created_at", "direction": "DESC" }
        ],
        "fields": ["id", "platform", "command", "target", "status", "priority", "scheduled_at", "created_at", "created_by"]
      },
      "filters": [
        {
          "id": "status-filter",
          "type": "multi-select",
          "label": "Trạng thái",
          "field": "status",
          "options": ["scheduled", "pending", "running", "completed", "failed", "cancelled"]
        },
        {
          "id": "platform-filter",
          "type": "multi-select",
          "label": "Nền tảng",
          "field": "platform",
          "options": ["douyin", "xhs", "bilibili", "weibo", "kuaishou", "tieba", "zhihu", "tiktok"]
        },
        {
          "id": "priority-filter",
          "type": "select",
          "label": "Ưu tiên",
          "field": "priority",
          "options": ["critical", "high", "normal", "low"]
        }
      ],
      "columns": [
        { "key": "platform", "label": "Nền tảng", "type": "platform-badge", "width": 100 },
        { "key": "command", "label": "Loại", "type": "badge", "width": 120 },
        { "key": "target", "label": "Target", "type": "text-truncate", "maxChars": 40 },
        { "key": "priority", "label": "Ưu tiên", "type": "priority-badge", "width": 90 },
        { "key": "status", "label": "Trạng thái", "type": "status-badge", "width": 110 },
        { "key": "scheduled_at", "label": "Lên lịch lúc", "type": "datetime", "width": 140 },
        { "key": "created_at", "label": "Tạo lúc", "type": "relative-time", "width": 120 },
        {
          "key": "actions",
          "label": "",
          "type": "action-menu",
          "width": 80,
          "actions": [
            { "id": "view-log", "label": "Xem Log", "icon": "TerminalIcon", "action": "open-console" },
            { "id": "clone", "label": "Nhân bản Task", "icon": "CopyIcon", "action": "clone-task", "role": "admin" },
            { "id": "cancel-task", "label": "Hủy Task", "icon": "XCircleIcon", "variant": "destructive", "action": "cancel-task", "role": "admin", "confirmText": "Bạn có chắc muốn hủy task này?" },
            { "id": "delete-task", "label": "Xóa", "icon": "TrashIcon", "variant": "destructive", "action": "delete-task", "role": "admin", "confirmText": "Xóa task này khỏi hệ thống?" }
          ]
        }
      ],
      "emptyState": {
        "icon": "InboxIcon",
        "title": "Chưa có nhiệm vụ nào",
        "description": "Nhấn 'Tạo nhiệm vụ mới' để bắt đầu cào dữ liệu"
      },
      "pagination": { "pageSize": 20, "showTotal": true }
    },
    {
      "id": "console-panel",
      "type": "console-panel",
      "description": "Console hiển thị live logs khi chọn 1 task đang chạy. Vị trí sẽ được quyết định ở bước thiết kế UI (Split/Bottom Panel/Standalone).",
      "dataSource": {
        "table": "crawler_logs",
        "realtimeSubscription": true,
        "filterBy": "task_id",
        "orderBy": "created_at ASC",
        "fields": ["level", "message", "created_at"]
      },
      "ui": {
        "background": "oklch(0.15 0 0)",
        "fontFamily": "Geist Mono, Courier New, monospace",
        "fontSize": "text-xs",
        "logColors": {
          "INFO": "#86efac",
          "DEBUG": "#9ca3af",
          "WARN": "#fbbf24",
          "ERROR": "#f87171"
        },
        "controls": [
          { "id": "auto-scroll", "type": "toggle", "label": "Auto-scroll", "defaultOn": true },
          { "id": "pause", "type": "toggle", "label": "Tạm dừng stream", "icon": "PauseIcon" },
          { "id": "clear", "type": "button", "label": "Xóa màn hình", "icon": "TrashIcon" },
          { "id": "export-log", "type": "button", "label": "Tải .txt", "icon": "ArrowDownTrayIcon" }
        ]
      }
    }
  ]
}
