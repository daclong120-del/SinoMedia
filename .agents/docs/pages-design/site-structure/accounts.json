{
  "$schema": "sinomedia-page-spec/v1",
  "route": "/dash/accounts",
  "title": "Quản lý tài khoản crawler",
  "titleEn": "Crawler Accounts",
  "priority": "P0",
  "minRole": "admin",
  "layout": { "type": "dashboard", "sidebar": true, "header": true, "padding": "px-4 md:px-8 py-6", "maxWidth": "max-w-[1400px]" },
  "header": {
    "breadcrumb": ["SinoMedia", "Crawler Controller", "Tài khoản"],
    "title": "Quản lý tài khoản crawler",
    "actions": [
      { "id": "add-account-btn", "label": "Nạp tài khoản mới", "type": "button", "variant": "primary", "icon": "PlusIcon", "action": "open-add-account-modal" }
    ]
  },
  "sections": [
    {
      "id": "pool-stats",
      "type": "metric-cards-row",
      "layout": "grid-4",
      "cards": [
        { "id": "total-active", "label": "Tổng Active", "icon": "CheckCircleIcon", "color": "emerald", "dataSource": { "table": "crawler_accounts", "query": "COUNT(*) WHERE status='active'" } },
        { "id": "total-banned", "label": "Tổng Banned", "icon": "XCircleIcon", "color": "red", "dataSource": { "table": "crawler_accounts", "query": "COUNT(*) WHERE status='banned'" } },
        { "id": "total-accounts", "label": "Tổng tài khoản", "icon": "UsersIcon", "color": "blue", "dataSource": { "table": "crawler_accounts", "query": "COUNT(*)" } },
        { "id": "health-rate", "label": "Tỷ lệ sống", "format": "percentage", "color": "violet", "icon": "HeartIcon", "dataSource": { "table": "crawler_accounts", "query": "active/total*100" } }
      ]
    },
    {
      "id": "add-account-modal",
      "type": "modal-form",
      "trigger": "add-account-btn",
      "title": "Nạp tài khoản cào mới",
      "width": "max-w-xl",
      "fields": [
        { "id": "platform", "label": "Nền tảng", "type": "select", "required": true, "options": ["douyin","xhs","bilibili","weibo","kuaishou","tieba","zhihu","tiktok"] },
        { "id": "alias", "label": "Tên gợi nhớ", "type": "text", "required": true, "placeholder": "VD: douyin_account_01" },
        { "id": "cookie", "label": "Cookie", "type": "textarea", "required": true, "rows": 6, "placeholder": "Raw string hoặc Chrome JSON format", "helpText": "Raw: key=val; key2=val2 | hoặc JSON array từ EditThisCookie" },
        { "id": "proxy", "label": "Proxy riêng (tùy chọn)", "type": "text", "placeholder": "IP:Port:Username:Password", "helpText": "Để trống = dùng Rotating Pool" }
      ],
      "actions": [
        { "id": "cancel", "label": "Hủy", "variant": "outline", "action": "close-modal" },
        { "id": "submit", "label": "Nạp tài khoản", "variant": "primary" }
      ]
    },
    {
      "id": "accounts-table",
      "type": "data-table-with-filters",
      "title": "Danh sách tài khoản",
      "dataSource": { "table": "crawler_accounts", "orderBy": [{ "field": "last_used_at", "direction": "ASC" }] },
      "filters": [
        { "id": "platform-filter", "type": "multi-select", "label": "Nền tảng", "field": "platform" },
        { "id": "status-filter", "type": "select", "label": "Trạng thái", "field": "status", "options": ["active","banned"] }
      ],
      "columns": [
        { "key": "alias", "label": "Tên tài khoản", "type": "text-bold" },
        { "key": "platform", "label": "Nền tảng", "type": "platform-badge" },
        { "key": "status", "label": "Trạng thái", "type": "status-badge", "badgeVariants": { "active": "emerald", "banned": "red" } },
        { "key": "failure_count", "label": "Lỗi liên tiếp", "type": "number-with-threshold", "threshold": { "warn": 1, "danger": 3 } },
        { "key": "proxy", "label": "Proxy", "type": "text-truncate", "fallback": "Rotating Pool" },
        { "key": "last_used_at", "label": "Dùng lần cuối", "type": "relative-time" },
        {
          "key": "actions", "label": "", "type": "action-menu",
          "actions": [
            { "id": "edit-cookie", "label": "Sửa Cookie", "icon": "PencilIcon", "action": "open-edit-modal" },
            { "id": "unban", "label": "Unban / Reset Lỗi", "icon": "ArrowPathIcon", "action": "unban-account", "showWhen": { "field": "status", "equals": "banned" } },
            { "id": "test", "label": "Test Cookie", "icon": "BeakerIcon", "action": "test-account-cookie" },
            { "id": "delete", "label": "Xóa", "variant": "destructive", "action": "delete-account", "confirmText": "Xóa tài khoản này?" }
          ]
        }
      ],
      "inlineInfo": { "message": "Hệ thống tự động chọn tài khoản Active có last_used_at cũ nhất khi cào. Tài khoản lỗi ≥ 3 lần sẽ tự động Banned." },
      "pagination": { "pageSize": 30 }
    }
  ]
}
