{
  "$schema": "sinomedia-page-spec/v1",
  "route": "/dash/audit-logs",
  "title": "Nhật ký hoạt động Admin",
  "titleEn": "Audit Logs",
  "priority": "P1",
  "minRole": "admin",
  "layout": { "type": "dashboard", "sidebar": true, "header": true, "padding": "px-4 md:px-8 py-6", "maxWidth": "max-w-[1400px]" },
  "header": {
    "breadcrumb": ["SinoMedia", "Admin", "Audit Logs"],
    "title": "Nhật ký hoạt động Admin"
  },
  "filterBar": {
    "position": "top",
    "filters": [
      { "id": "actor", "type": "search-input", "placeholder": "Tìm theo email Admin...", "field": "actor_id" },
      { "id": "action_type", "type": "multi-select", "label": "Loại hành động", "field": "action", "options": [
        "account.add", "account.update_cookie", "account.unban", "account.delete",
        "task.create", "task.cancel", "task.delete",
        "post.delete", "post.tag",
        "author.delete",
        "data.export",
        "settings.update",
        "permission.update"
      ]},
      { "id": "date_range", "type": "date-range-picker", "label": "Khoảng thời gian", "fields": { "from": "created_at_from", "to": "created_at_to" } }
    ]
  },
  "sections": [
    {
      "id": "audit-timeline",
      "type": "audit-timeline",
      "dataSource": {
        "table": "audit_logs",
        "orderBy": [{ "field": "created_at", "direction": "DESC" }],
        "fields": ["id","actor_id","action","entity_type","entity_id","payload","created_at","ip_address"]
      },
      "item": {
        "icon": { "key": "action", "iconMap": {
          "account.*": "KeyIcon",
          "task.*": "PlayCircleIcon",
          "post.*": "DocumentTextIcon",
          "data.export": "ArrowDownTrayIcon",
          "settings.*": "CogIcon",
          "permission.*": "ShieldCheckIcon"
        }},
        "title": { "template": "{actor_id} đã {action_label}" },
        "subtitle": { "template": "{entity_type} #{entity_id}" },
        "meta": [
          { "key": "created_at", "type": "datetime" },
          { "key": "ip_address", "label": "IP" }
        ],
        "expandable": true,
        "expandContent": { "type": "json-viewer", "key": "payload" }
      },
      "emptyState": { "icon": "DocumentMagnifyingGlassIcon", "title": "Không có log nào", "description": "Chưa có hành động nào được ghi nhận trong khoảng thời gian này" },
      "pagination": { "pageSize": 50, "showTotal": true }
    }
  ]
}
