{
  "$schema": "sinomedia-page-spec/v1",
  "route": "/dash/creative/advertisers/[id]",
  "title": "Hồ sơ Advertiser",
  "titleEn": "Advertiser Profile",
  "priority": "P2",
  "minRole": "viewer",
  "layout": {
    "type": "dashboard",
    "sidebar": true,
    "header": true,
    "padding": "px-4 md:px-8 py-6",
    "maxWidth": "max-w-[1400px]"
  },
  "header": {
    "breadcrumb": ["SinoMedia", "Creative Hub", "Advertiser", "{advertiser.nickname}"],
    "breadcrumbDynamic": { "key": "advertiser.nickname", "fallback": "Advertiser" },
    "title": "{advertiser.nickname}",
    "titleDynamic": true,
    "actions": [
      {
        "id": "export-btn",
        "label": "Xuất creative",
        "labelEn": "Export Creatives",
        "type": "button",
        "variant": "outline",
        "icon": "ArrowDownTrayIcon",
        "action": "export-advertiser-creatives"
      }
    ]
  },
  "sections": [
    {
      "id": "advertiser-profile-header",
      "type": "profile-header-card",
      "dataSource": {
        "table": "crawled_authors",
        "filterBy": "id = :id",
        "fields": ["id", "nickname", "platform", "avatar_url", "fans_count", "description"]
      },
      "joinStats": {
        "endpoint": "GET /functions/creative-advertisers/:id/stats",
        "fields": ["creative_count", "total_views", "total_likes", "first_seen_at", "last_active_at"]
      },
      "layout": {
        "avatar": { "key": "avatar_url", "source": "r2", "size": 72 },
        "name": { "key": "nickname", "fontSize": "text-xl", "fontWeight": "font-bold" },
        "platformBadge": { "key": "platform" },
        "description": { "key": "description", "fontSize": "text-sm", "muted": true },
        "stats": [
          { "key": "creative_count", "label": "Creative", "format": "number-formatted" },
          { "key": "total_views", "label": "Tổng Views", "format": "number-short" },
          { "key": "total_likes", "label": "Tổng Likes", "format": "number-short" },
          { "key": "fans_count", "label": "Followers", "format": "number-short" }
        ]
      }
    },
    {
      "id": "advertiser-tabs",
      "type": "tab-panels",
      "tabs": [
        {
          "id": "creatives-tab",
          "label": "Creative",
          "labelEn": "Creatives",
          "icon": "PhotoIcon",
          "content": {
            "id": "advertiser-creatives-grid",
            "type": "creative-card-grid",
            "dataSource": {
              "table": "crawled_posts",
              "filterBy": "author_id = :id",
              "orderBy": [{ "field": "view_count", "direction": "DESC" }],
              "fields": ["id", "platform", "caption", "cover_url", "media_type", "view_count", "like_count", "comment_count", "published_at"]
            },
            "gridLayout": {
              "cols": { "default": 2, "sm": 3, "md": 4, "lg": 5 },
              "gap": 4
            },
            "card": {
              "coverImage": { "key": "cover_url", "source": "r2", "aspectRatio": "9/16" },
              "platformBadge": { "key": "platform", "position": "top-left" },
              "body": [
                { "key": "caption", "type": "text-truncate", "lines": 2, "fontSize": "text-xs" }
              ],
              "metrics": [
                { "key": "view_count", "icon": "EyeIcon", "format": "number-short" },
                { "key": "like_count", "icon": "HeartIcon", "format": "number-short" }
              ],
              "clickAction": { "navigate": "/dash/creative/{id}" }
            },
            "emptyState": {
              "icon": "PhotoIcon",
              "title": "Advertiser này chưa có creative nào"
            },
            "pagination": { "pageSize": 40, "showTotal": true }
          }
        },
        {
          "id": "trend-tab",
          "label": "Xu hướng",
          "labelEn": "Trends",
          "icon": "ChartBarIcon",
          "content": {
            "id": "advertiser-trend-chart",
            "type": "line-chart",
            "title": "Views theo thời gian",
            "titleEn": "Views Over Time",
            "dataSource": {
              "endpoint": "GET /functions/creative-advertisers/:id/trend",
              "groupBy": "DATE(published_at)",
              "period": "90d"
            },
            "xAxis": "date",
            "yAxis": "total_views",
            "color": "blue",
            "showDots": true,
            "showGrid": true,
            "height": 300
          }
        }
      ]
    },
    {
      "id": "top-creatives",
      "type": "featured-cards-row",
      "title": "Top Creative nổi bật",
      "titleEn": "Top Creatives",
      "limit": 5,
      "dataSource": {
        "table": "crawled_posts",
        "filterBy": "author_id = :id",
        "orderBy": [{ "field": "view_count", "direction": "DESC" }],
        "fields": ["id", "platform", "caption", "cover_url", "view_count", "like_count"]
      },
      "card": {
        "coverImage": { "key": "cover_url", "source": "r2", "aspectRatio": "16/9" },
        "platformBadge": { "key": "platform", "position": "top-left" },
        "body": [{ "key": "caption", "type": "text-truncate", "lines": 1 }],
        "metrics": [
          { "key": "view_count", "icon": "EyeIcon", "format": "number-short" },
          { "key": "like_count", "icon": "HeartIcon", "format": "number-short" }
        ],
        "clickAction": { "navigate": "/dash/creative/{id}" }
      }
    }
  ]
}
