{
  "$schema": "sinomedia-page-spec/v1",
  "route": "/dash/creative/trending",
  "title": "Xu hướng mới nhất",
  "titleEn": "Trending Creatives",
  "priority": "P0",
  "minRole": "viewer",
  "layout": {
    "type": "dashboard",
    "sidebar": true,
    "header": true,
    "padding": "px-4 md:px-8 py-6",
    "maxWidth": "max-w-[1400px]"
  },
  "header": {
    "breadcrumb": ["SinoMedia", "Creative Hub", "BXH", "Xu hướng mới nhất"],
    "title": "BXH Creative — Xu hướng mới nhất",
    "titleEn": "Creative Rankings — Trending",
    "actions": []
  },
  "sections": [
    {
      "id": "period-tabs",
      "type": "tab-bar",
      "field": "period",
      "tabs": [
        { "value": "7d", "label": "7 Ngày", "default": true },
        { "value": "30d", "label": "30 Ngày" },
        { "value": "90d", "label": "90 Ngày" }
      ]
    },
    {
      "id": "platform-filter",
      "type": "filter-chips",
      "field": "platform",
      "allLabel": "Tất cả",
      "allLabelEn": "All",
      "options": [
        { "value": "douyin", "label": "Douyin" },
        { "value": "kuaishou", "label": "Kuaishou" },
        { "value": "xhs", "label": "XHS" },
        { "value": "bilibili", "label": "Bilibili" },
        { "value": "weibo", "label": "Weibo" },
        { "value": "zhihu", "label": "Zhihu" },
        { "value": "tieba", "label": "Tieba" },
        { "value": "tiktok", "label": "TikTok" }
      ]
    },
    {
      "id": "top-featured",
      "type": "featured-cards-row",
      "description": "Top 3 creative nổi bật nhất — card lớn hơn",
      "limit": 3,
      "dataSource": {
        "table": "crawled_posts",
        "orderBy": [{ "field": "view_count", "direction": "DESC" }],
        "fields": ["id", "platform", "author_id", "caption", "cover_url", "view_count", "like_count", "comment_count", "published_at"]
      },
      "card": {
        "coverImage": { "key": "cover_url", "source": "r2", "aspectRatio": "16/9" },
        "platformBadge": { "key": "platform", "position": "top-left" },
        "rankBadge": { "position": "top-right", "colors": { "1": "gold", "2": "silver", "3": "bronze" } },
        "body": [
          { "key": "caption", "type": "text-truncate", "lines": 2 }
        ],
        "metrics": [
          { "key": "view_count", "icon": "EyeIcon", "format": "number-short", "primary": true },
          { "key": "like_count", "icon": "HeartIcon", "format": "number-short" }
        ],
        "clickAction": { "navigate": "/dash/creative/{id}" }
      }
    },
    {
      "id": "ranking-table",
      "type": "data-table-with-filters",
      "title": "Bảng xếp hạng",
      "titleEn": "Rankings",
      "dataSource": {
        "table": "crawled_posts",
        "orderBy": [{ "field": "view_count", "direction": "DESC" }],
        "fields": ["id", "platform", "author_id", "caption", "cover_url", "view_count", "like_count", "comment_count", "share_count", "published_at", "crawled_at"]
      },
      "columns": [
        { "key": "_rank", "label": "#", "type": "rank-number", "width": 50 },
        { "key": "cover_url", "label": "", "type": "thumbnail", "width": 72, "aspectRatio": "16/9", "source": "r2" },
        { "key": "caption", "label": "Nội dung", "labelEn": "Content", "type": "text-truncate", "maxChars": 60 },
        { "key": "platform", "label": "Nền tảng", "labelEn": "Platform", "type": "platform-badge", "width": 100 },
        {
          "key": "author_id",
          "label": "Advertiser",
          "type": "author-link",
          "lookupTable": "crawled_authors",
          "displayField": "nickname",
          "linkTo": "/dash/creative/advertisers/{author_id}"
        },
        { "key": "view_count", "label": "Views", "type": "number-formatted", "width": 100, "sortable": true },
        { "key": "like_count", "label": "Likes", "type": "number-formatted", "width": 90, "sortable": true },
        {
          "key": "sparkline",
          "label": "Xu hướng 7 ngày",
          "labelEn": "7-day Trend",
          "type": "sparkline-chart",
          "width": 120,
          "dataKey": "view_history",
          "color": "blue"
        },
        { "key": "published_at", "label": "Ngày đăng", "type": "date", "width": 100 }
      ],
      "rowClick": { "action": "navigate", "href": "/dash/creative/{id}" },
      "emptyState": {
        "icon": "ChartBarIcon",
        "title": "Chưa có dữ liệu xu hướng",
        "description": "Dữ liệu creative sẽ hiển thị sau khi crawler thu thập đủ"
      },
      "pagination": { "pageSize": 50, "showTotal": true }
    }
  ]
}
