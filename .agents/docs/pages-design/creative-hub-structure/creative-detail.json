{
  "$schema": "sinomedia-page-spec/v1",
  "route": "/dash/creative/[id]",
  "title": "Chi tiết Creative",
  "titleEn": "Creative Detail",
  "priority": "P0",
  "minRole": "viewer",
  "layout": {
    "type": "dashboard",
    "sidebar": true,
    "header": true,
    "padding": "px-4 md:px-8 py-6",
    "maxWidth": "max-w-[1400px]"
  },
  "header": {
    "breadcrumb": ["SinoMedia", "Creative Hub", "Chi tiết Creative"],
    "title": "Chi tiết Creative",
    "titleEn": "Creative Detail",
    "actions": [
      {
        "id": "copy-link",
        "label": "Sao chép link",
        "labelEn": "Copy Link",
        "type": "button",
        "variant": "outline",
        "icon": "LinkIcon",
        "action": "copy-creative-url"
      },
      {
        "id": "export-btn",
        "label": "Xuất thông tin",
        "labelEn": "Export Info",
        "type": "button",
        "variant": "outline",
        "icon": "ArrowDownTrayIcon",
        "action": "export-creative-detail"
      }
    ]
  },
  "sections": [
    {
      "id": "creative-detail-split",
      "type": "split-layout",
      "description": "Split layout: media bên trái 60%, thông tin bên phải 40%",
      "ratio": "60/40",
      "responsiveBreakpoint": "lg",
      "responsiveStack": "vertical",
      "dataSource": {
        "table": "crawled_posts",
        "filterBy": "id = :id",
        "joinTables": [
          { "table": "crawled_authors", "on": "author_id = crawled_authors.id", "fields": ["nickname", "avatar_url", "platform"] }
        ],
        "fields": ["id", "platform", "author_id", "title", "caption", "cover_url", "media_urls", "media_type", "like_count", "view_count", "comment_count", "share_count", "tags", "published_at", "crawled_at"]
      },
      "left": {
        "id": "media-viewer",
        "type": "media-player",
        "mediaKey": "media_urls",
        "coverKey": "cover_url",
        "source": "r2",
        "supportTypes": ["video", "image-slider"],
        "videoControls": true,
        "imageNavigation": "dots",
        "maxHeight": "70vh",
        "background": "bg-black rounded-xl overflow-hidden"
      },
      "right": {
        "id": "creative-info-panel",
        "type": "info-panel",
        "sections": [
          {
            "id": "platform-author-row",
            "type": "platform-author-header",
            "platform": { "key": "platform" },
            "author": {
              "avatar": { "key": "author.avatar_url", "source": "r2", "size": 36 },
              "name": { "key": "author.nickname" },
              "linkTo": "/dash/creative/advertisers/{author_id}"
            }
          },
          {
            "id": "timestamps",
            "type": "info-rows",
            "rows": [
              { "label": "Ngày đăng", "labelEn": "Published", "key": "published_at", "format": "datetime" },
              { "label": "Ngày crawl", "labelEn": "Crawled", "key": "crawled_at", "format": "relative-time" }
            ]
          },
          {
            "id": "metrics-grid",
            "type": "metrics-row",
            "layout": "grid-2x2",
            "metrics": [
              { "key": "view_count", "label": "Views", "icon": "EyeIcon", "format": "number-formatted", "color": "blue" },
              { "key": "like_count", "label": "Likes", "icon": "HeartIcon", "format": "number-formatted", "color": "red" },
              { "key": "comment_count", "label": "Comments", "icon": "ChatBubbleIcon", "format": "number-formatted", "color": "amber" },
              { "key": "share_count", "label": "Shares", "icon": "ShareIcon", "format": "number-formatted", "color": "emerald" }
            ]
          },
          {
            "id": "caption-block",
            "type": "text-block",
            "key": "caption",
            "label": "Nội dung",
            "labelEn": "Caption",
            "expandable": true,
            "maxLines": 6,
            "fontSize": "text-sm"
          },
          {
            "id": "tags-section",
            "type": "tags-list",
            "key": "tags",
            "label": "Tags",
            "editable": true,
            "editRole": "admin",
            "addAction": "open-tag-modal"
          },
          {
            "id": "action-buttons",
            "type": "action-button-row",
            "actions": [
              {
                "id": "tag-creative",
                "label": "Gán tag",
                "labelEn": "Add Tag",
                "icon": "TagIcon",
                "variant": "outline",
                "action": "open-tag-modal",
                "role": "admin"
              }
            ]
          }
        ]
      }
    },
    {
      "id": "related-creatives",
      "type": "related-items-carousel",
      "title": "Creative tương tự",
      "titleEn": "Similar Creatives",
      "description": "Creative cùng advertiser hoặc cùng tags",
      "dataSource": {
        "strategy": "same-author-then-same-tags",
        "table": "crawled_posts",
        "excludeId": ":id",
        "limit": 10,
        "orderBy": [{ "field": "view_count", "direction": "DESC" }],
        "fields": ["id", "platform", "caption", "cover_url", "view_count", "like_count"]
      },
      "cardLayout": "horizontal-scroll",
      "card": {
        "width": 180,
        "coverImage": { "key": "cover_url", "source": "r2", "aspectRatio": "9/16", "height": 240 },
        "platformBadge": { "key": "platform", "position": "top-left", "size": "sm" },
        "body": [
          { "key": "caption", "type": "text-truncate", "lines": 1, "fontSize": "text-xs" }
        ],
        "metrics": [
          { "key": "view_count", "icon": "EyeIcon", "format": "number-short" }
        ],
        "clickAction": { "navigate": "/dash/creative/{id}" }
      },
      "emptyState": {
        "title": "Không tìm thấy creative tương tự"
      }
    }
  ]
}
