{
  "$schema": "sinomedia-page-spec/v1",
  "route": "/dash/creative/new",
  "title": "Creative mới",
  "titleEn": "New Creatives",
  "priority": "P1",
  "minRole": "viewer",
  "layout": {
    "type": "dashboard",
    "sidebar": true,
    "header": true,
    "padding": "px-4 md:px-8 py-6",
    "maxWidth": "max-w-[1400px]"
  },
  "header": {
    "breadcrumb": ["SinoMedia", "Creative Hub", "BXH", "Creative mới"],
    "title": "Creative mới",
    "titleEn": "New Creatives",
    "actions": [
      {
        "id": "auto-refresh-toggle",
        "label": "Tự động cập nhật",
        "labelEn": "Auto Refresh",
        "type": "toggle",
        "defaultOn": false,
        "interval": 30000,
        "action": "toggle-auto-refresh"
      }
    ]
  },
  "sections": [
    {
      "id": "platform-filter",
      "type": "filter-chips",
      "field": "platform",
      "allLabel": "Tất cả",
      "options": [
        { "value": "douyin", "label": "Douyin" },
        { "value": "kuaishou", "label": "Kuaishou" },
        { "value": "xhs", "label": "XHS" },
        { "value": "bilibili", "label": "Bilibili" },
        { "value": "weibo", "label": "Weibo" },
        { "value": "zhihu", "label": "Zhihu" },
        { "value": "tieba", "label": "Tieba" },
        { "value": "tiktok", "label": "TikTok" }
      ]
    },
    {
      "id": "new-creative-grid",
      "type": "creative-card-grid",
      "description": "Feed creative mới nhất, sort theo crawled_at DESC",
      "dataSource": {
        "table": "crawled_posts",
        "orderBy": [{ "field": "crawled_at", "direction": "DESC" }],
        "fields": ["id", "platform", "author_id", "caption", "cover_url", "media_type", "like_count", "view_count", "comment_count", "published_at", "crawled_at"],
        "realtimeSubscription": true
      },
      "gridLayout": {
        "cols": { "default": 2, "sm": 3, "md": 4, "lg": 5 },
        "gap": 4
      },
      "card": {
        "coverImage": { "key": "cover_url", "source": "r2", "aspectRatio": "9/16" },
        "platformBadge": { "key": "platform", "position": "top-left" },
        "newBadge": {
          "enabled": true,
          "thresholdHours": 24,
          "key": "crawled_at",
          "label": "Mới",
          "labelEn": "New",
          "color": "emerald",
          "position": "top-right"
        },
        "body": [
          { "key": "caption", "type": "text-truncate", "lines": 2, "fontSize": "text-xs" }
        ],
        "metrics": [
          { "key": "view_count", "icon": "EyeIcon", "format": "number-short" },
          { "key": "like_count", "icon": "HeartIcon", "format": "number-short" }
        ],
        "footer": {
          "advertiser": { "key": "author_id", "lookupTable": "crawled_authors", "displayField": "nickname" },
          "date": { "key": "crawled_at", "type": "relative-time", "prefix": "Crawl " }
        },
        "clickAction": { "navigate": "/dash/creative/{id}" }
      },
      "emptyState": {
        "icon": "SparklesIcon",
        "title": "Chưa có creative mới",
        "description": "Creative sẽ xuất hiện tại đây khi crawler thu thập được dữ liệu mới"
      },
      "pagination": { "pageSize": 50, "showTotal": true }
    }
  ]
}
