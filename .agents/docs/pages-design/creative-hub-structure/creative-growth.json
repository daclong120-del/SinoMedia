{
  "$schema": "sinomedia-page-spec/v1",
  "route": "/dash/creative/growth",
  "title": "Tăng trưởng nhanh",
  "titleEn": "Fast Growing Creatives",
  "priority": "P1",
  "minRole": "viewer",
  "layout": {
    "type": "dashboard",
    "sidebar": true,
    "header": true,
    "padding": "px-4 md:px-8 py-6",
    "maxWidth": "max-w-[1400px]"
  },
  "header": {
    "breadcrumb": ["SinoMedia", "Creative Hub", "BXH", "Tăng trưởng nhanh"],
    "title": "BXH Creative — Tăng trưởng nhanh",
    "titleEn": "Creative Rankings — Fast Growing",
    "actions": []
  },
  "sections": [
    {
      "id": "comparison-period",
      "type": "select-bar",
      "label": "Kỳ so sánh",
      "labelEn": "Comparison Period",
      "field": "comparison_period",
      "options": [
        { "value": "7d_vs_7d", "label": "7 ngày gần nhất vs 7 ngày trước đó", "default": true },
        { "value": "30d_vs_30d", "label": "30 ngày gần nhất vs 30 ngày trước đó" },
        { "value": "7d_vs_30d", "label": "7 ngày gần nhất vs 30 ngày trước đó" }
      ]
    },
    {
      "id": "platform-filter",
      "type": "filter-chips",
      "field": "platform",
      "allLabel": "Tất cả",
      "options": [
        { "value": "douyin", "label": "Douyin" },
        { "value": "kuaishou", "label": "Kuaishou" },
        { "value": "xhs", "label": "XHS" },
        { "value": "bilibili", "label": "Bilibili" },
        { "value": "weibo", "label": "Weibo" },
        { "value": "zhihu", "label": "Zhihu" },
        { "value": "tieba", "label": "Tieba" },
        { "value": "tiktok", "label": "TikTok" }
      ]
    },
    {
      "id": "sort-bar",
      "type": "sort-toggle",
      "options": [
        { "value": "growth_pct_desc", "label": "Tăng trưởng % cao nhất", "default": true },
        { "value": "growth_abs_desc", "label": "Tăng trưởng tuyệt đối" }
      ],
      "field": "sort_by"
    },
    {
      "id": "growth-grid",
      "type": "creative-card-grid",
      "description": "Grid creative với growth badge nổi bật",
      "dataSource": {
        "endpoint": "GET /functions/creative-growth",
        "fields": ["id", "platform", "author_id", "caption", "cover_url", "view_count", "like_count", "view_count_prev", "like_count_prev", "growth_pct", "growth_abs", "published_at"]
      },
      "gridLayout": {
        "cols": { "default": 2, "sm": 3, "md": 4, "lg": 5 },
        "gap": 4
      },
      "card": {
        "coverImage": { "key": "cover_url", "source": "r2", "aspectRatio": "9/16" },
        "platformBadge": { "key": "platform", "position": "top-left" },
        "growthBadge": {
          "position": "top-right",
          "key": "growth_pct",
          "format": "+{value}%",
          "colors": {
            "positive": { "bg": "emerald-500/15", "text": "emerald-600" },
            "negative": { "bg": "red-500/15", "text": "red-600" }
          }
        },
        "body": [
          { "key": "caption", "type": "text-truncate", "lines": 2, "fontSize": "text-xs" }
        ],
        "metrics": [
          { "key": "view_count", "icon": "EyeIcon", "format": "number-short", "label": "Hiện tại" },
          { "key": "view_count_prev", "icon": "EyeIcon", "format": "number-short", "label": "Kỳ trước", "muted": true }
        ],
        "sparkline": {
          "dataKey": "view_history",
          "color": "emerald",
          "height": 32
        },
        "clickAction": { "navigate": "/dash/creative/{id}" }
      },
      "emptyState": {
        "icon": "ArrowTrendingUpIcon",
        "title": "Chưa có dữ liệu tăng trưởng",
        "description": "Cần ít nhất 2 kỳ dữ liệu để tính tăng trưởng. Tiếp tục chạy crawler để thu thập."
      },
      "pagination": { "pageSize": 40, "showTotal": true }
    }
  ]
}
