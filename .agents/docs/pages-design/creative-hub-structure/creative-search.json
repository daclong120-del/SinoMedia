{
  "$schema": "sinomedia-page-spec/v1",
  "route": "/dash/creative/search",
  "title": "Tìm Creative",
  "titleEn": "Search Creatives",
  "priority": "P0",
  "minRole": "viewer",
  "layout": {
    "type": "dashboard",
    "sidebar": true,
    "header": true,
    "padding": "px-4 md:px-8 py-6",
    "maxWidth": "max-w-[1600px]"
  },
  "header": {
    "breadcrumb": ["SinoMedia", "Creative Hub", "Tìm Creative"],
    "title": "Tìm Creative",
    "titleEn": "Search Creatives",
    "actions": [
      {
        "id": "export-btn",
        "label": "Xuất danh sách",
        "labelEn": "Export List",
        "type": "button",
        "variant": "outline",
        "icon": "ArrowDownTrayIcon",
        "action": "export-creative-list"
      }
    ]
  },
  "searchBar": {
    "id": "creative-search-input",
    "type": "search-hero",
    "placeholder": "Tìm theo caption, hashtag, tên advertiser...",
    "placeholderEn": "Search by caption, hashtag, advertiser name...",
    "fullWidth": true,
    "size": "lg",
    "submitLabel": "Tìm kiếm",
    "submitIcon": "MagnifyingGlassIcon"
  },
  "filterBar": {
    "position": "below-search",
    "layout": "horizontal-wrap",
    "filterPayload": "json-to-backend",
    "filters": [
      {
        "id": "platform",
        "type": "multi-select-chips",
        "label": "Nền tảng",
        "labelEn": "Platform",
        "field": "platform",
        "options": [
          { "value": "douyin", "label": "Douyin", "icon": "DouyinIcon" },
          { "value": "kuaishou", "label": "Kuaishou", "icon": "KuaishouIcon" },
          { "value": "xhs", "label": "XHS", "icon": "XhsIcon" },
          { "value": "bilibili", "label": "Bilibili", "icon": "BilibiliIcon" },
          { "value": "weibo", "label": "Weibo", "icon": "WeiboIcon" },
          { "value": "zhihu", "label": "Zhihu", "icon": "ZhihuIcon" },
          { "value": "tieba", "label": "Tieba", "icon": "TiebaIcon" },
          { "value": "tiktok", "label": "TikTok", "icon": "TiktokIcon" }
        ]
      },
      {
        "id": "media_type",
        "type": "multi-select-chips",
        "label": "Loại media",
        "labelEn": "Media Type",
        "field": "media_type",
        "options": [
          { "value": "video", "label": "Video" },
          { "value": "image", "label": "Ảnh" },
          { "value": "carousel", "label": "Carousel" }
        ]
      },
      {
        "id": "time_range",
        "type": "select",
        "label": "Khoảng thời gian",
        "labelEn": "Time Range",
        "field": "time_range",
        "options": [
          { "value": "7d", "label": "7 ngày" },
          { "value": "30d", "label": "30 ngày" },
          { "value": "90d", "label": "90 ngày" },
          { "value": "1y", "label": "1 năm" },
          { "value": "custom", "label": "Tùy chọn" }
        ],
        "defaultValue": "30d"
      },
      {
        "id": "date_range",
        "type": "date-range-picker",
        "label": "Khoảng ngày",
        "labelEn": "Date Range",
        "fields": { "from": "published_at_from", "to": "published_at_to" },
        "showWhen": { "field": "time_range", "equals": "custom" }
      },
      {
        "id": "sort_by",
        "type": "select",
        "label": "Sắp xếp",
        "labelEn": "Sort By",
        "field": "sort_by",
        "options": [
          { "value": "view_count_desc", "label": "Views cao nhất" },
          { "value": "like_count_desc", "label": "Likes cao nhất" },
          { "value": "comment_count_desc", "label": "Comments nhiều nhất" },
          { "value": "published_at_desc", "label": "Mới nhất" },
          { "value": "published_at_asc", "label": "Cũ nhất" }
        ],
        "defaultValue": "view_count_desc"
      }
    ],
    "advancedFilters": {
      "toggleLabel": "Lọc nâng cao",
      "toggleLabelEn": "Advanced Filters",
      "filters": [
        { "id": "views_min", "type": "number", "label": "View tối thiểu", "field": "view_count", "operator": "gte" },
        { "id": "likes_min", "type": "number", "label": "Like tối thiểu", "field": "like_count", "operator": "gte" },
        { "id": "language", "type": "select", "label": "Ngôn ngữ caption", "field": "language", "options": [
          { "value": "zh", "label": "Tiếng Trung" },
          { "value": "en", "label": "Tiếng Anh" },
          { "value": "other", "label": "Khác" }
        ]}
      ]
    }
  },
  "sections": [
    {
      "id": "result-summary",
      "type": "result-summary-bar",
      "showTotal": true,
      "totalTemplate": "Tìm thấy {count} creative",
      "totalTemplateEn": "Found {count} creatives",
      "quickTabs": [
        { "value": "all", "label": "Tất cả" },
        { "value": "ad", "label": "Quảng cáo" },
        { "value": "organic", "label": "Tự nhiên" }
      ],
      "quickTabField": "content_type"
    },
    {
      "id": "creative-grid",
      "type": "creative-card-grid",
      "dataSource": {
        "table": "crawled_posts",
        "orderBy": [{ "field": "view_count", "direction": "DESC" }],
        "fields": ["id", "platform", "author_id", "title", "caption", "cover_url", "media_type", "like_count", "view_count", "comment_count", "share_count", "media_urls", "tags", "published_at", "crawled_at"]
      },
      "gridLayout": {
        "cols": { "default": 2, "sm": 3, "md": 4, "lg": 5 },
        "gap": 4
      },
      "card": {
        "coverImage": { "key": "cover_url", "source": "r2", "aspectRatio": "9/16", "fallbackAspect": "16/9" },
        "platformBadge": { "key": "platform", "position": "top-left" },
        "mediaTypeBadge": { "key": "media_type", "position": "top-right" },
        "body": [
          { "key": "caption", "type": "text-truncate", "lines": 2, "fontSize": "text-xs" }
        ],
        "metrics": [
          { "key": "view_count", "icon": "EyeIcon", "format": "number-short" },
          { "key": "like_count", "icon": "HeartIcon", "format": "number-short" },
          { "key": "comment_count", "icon": "ChatBubbleIcon", "format": "number-short" }
        ],
        "footer": {
          "advertiser": { "key": "author_id", "lookupTable": "crawled_authors", "displayField": "nickname" },
          "date": { "key": "published_at", "type": "relative-time" }
        },
        "clickAction": { "navigate": "/dash/creative/{id}" }
      },
      "emptyState": {
        "icon": "MagnifyingGlassIcon",
        "title": "Không tìm thấy creative nào",
        "titleEn": "No creatives found",
        "description": "Thử thay đổi bộ lọc hoặc từ khóa tìm kiếm",
        "descriptionEn": "Try adjusting your filters or search terms"
      },
      "pagination": { "pageSize": 40, "showTotal": true }
    }
  ]
}
