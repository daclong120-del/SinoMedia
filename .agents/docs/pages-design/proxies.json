{
  "$schema": "sinomedia-page-spec/v1",
  "route": "/dash/proxies",
  "title": "Quản lý Proxy Pool",
  "titleEn": "Proxy Pool",
  "priority": "P0",
  "minRole": "admin",
  "layout": { "type": "dashboard", "sidebar": true, "header": true, "padding": "px-4 md:px-8 py-6", "maxWidth": "max-w-[1400px]" },
  "header": {
    "breadcrumb": ["SinoMedia", "Crawler Controller", "Proxy Pool"],
    "title": "Quản lý Proxy Pool",
    "actions": [
      { "id": "add-proxy-btn", "label": "Nạp Proxy", "type": "button", "variant": "primary", "icon": "PlusIcon", "action": "open-add-proxy-modal" }
    ]
  },
  "sections": [
    {
      "id": "proxy-mode-info",
      "type": "info-banner",
      "variant": "info",
      "content": "Có 2 chế độ: Sticky Proxy (gán cố định cho 1 tài khoản – cấu hình tại trang Accounts) và Rotating Pool (nạp vào đây, crawler tự xoay vòng ngẫu nhiên theo request)."
    },
    {
      "id": "proxy-stats",
      "type": "metric-cards-row",
      "layout": "grid-3",
      "cards": [
        { "id": "total-proxy", "label": "Tổng Proxy", "icon": "ServerIcon", "color": "blue", "dataSource": { "table": "proxy_pool", "query": "COUNT(*)" } },
        { "id": "active-proxy", "label": "Đang hoạt động", "icon": "CheckCircleIcon", "color": "emerald", "dataSource": { "table": "proxy_pool", "query": "COUNT(*) WHERE status='active'" } },
        { "id": "assigned-proxy", "label": "Đã gán cho Account", "icon": "LinkIcon", "color": "violet", "dataSource": { "table": "proxy_pool", "query": "COUNT(*) WHERE assigned_account_id IS NOT NULL" } }
      ]
    },
    {
      "id": "add-proxy-modal",
      "type": "modal-form",
      "trigger": "add-proxy-btn",
      "title": "Nạp Proxy mới",
      "width": "max-w-xl",
      "tabs": [
        {
          "id": "single",
          "label": "Nhập đơn",
          "fields": [
            { "id": "host", "label": "Host / IP", "type": "text", "required": true },
            { "id": "port", "label": "Port", "type": "number", "required": true },
            { "id": "username", "label": "Username", "type": "text" },
            { "id": "password", "label": "Password", "type": "password" },
            { "id": "protocol", "label": "Protocol", "type": "select", "options": ["http","https","socks5"], "defaultValue": "http" }
          ]
        },
        {
          "id": "bulk",
          "label": "Nhập hàng loạt",
          "fields": [
            { "id": "bulk_input", "label": "Danh sách proxy", "type": "textarea", "rows": 10, "placeholder": "IP:Port:User:Pass\nIP:Port:User:Pass\n...", "helpText": "Mỗi dòng một proxy theo định dạng IP:Port:User:Pass" }
          ]
        }
      ],
      "actions": [
        { "id": "cancel", "label": "Hủy", "variant": "outline", "action": "close-modal" },
        { "id": "submit", "label": "Nạp Proxy", "variant": "primary" }
      ]
    },
    {
      "id": "proxy-table",
      "type": "data-table-with-filters",
      "title": "Danh sách Proxy",
      "dataSource": { "table": "proxy_pool", "orderBy": [{ "field": "created_at", "direction": "DESC" }] },
      "filters": [
        { "id": "status-filter", "type": "select", "label": "Trạng thái", "field": "status", "options": ["active","inactive","dead"] },
        { "id": "protocol-filter", "type": "select", "label": "Protocol", "field": "protocol", "options": ["http","https","socks5"] },
        { "id": "assigned-filter", "type": "select", "label": "Gán cho account", "field": "assigned", "options": [{ "value": "yes", "label": "Đã gán" }, { "value": "no", "label": "Chưa gán" }] }
      ],
      "columns": [
        { "key": "host", "label": "Host:Port", "type": "composite", "fields": ["host","port"], "format": "{host}:{port}" },
        { "key": "protocol", "label": "Protocol", "type": "badge" },
        { "key": "username", "label": "Username", "type": "text", "fallback": "—" },
        { "key": "status", "label": "Trạng thái", "type": "status-badge", "badgeVariants": { "active": "emerald", "inactive": "amber", "dead": "red" } },
        { "key": "assigned_account_id", "label": "Gán cho Account", "type": "relation-link", "relation": "crawler_accounts", "displayField": "alias", "fallback": "Rotating Pool" },
        { "key": "last_used_at", "label": "Dùng lần cuối", "type": "relative-time" },
        {
          "key": "actions", "label": "", "type": "action-menu",
          "actions": [
            { "id": "test-proxy", "label": "Test Proxy", "icon": "BeakerIcon", "action": "test-proxy" },
            { "id": "assign-account", "label": "Gán cho Account", "icon": "LinkIcon", "action": "open-assign-modal" },
            { "id": "unassign", "label": "Bỏ gán", "icon": "MinusCircleIcon", "action": "unassign-proxy", "showWhen": { "field": "assigned_account_id", "notNull": true } },
            { "id": "delete", "label": "Xóa", "variant": "destructive", "action": "delete-proxy", "confirmText": "Xóa proxy này?" }
          ]
        }
      ],
      "pagination": { "pageSize": 50 }
    }
  ]
}
