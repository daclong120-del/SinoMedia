{
  "$schema": "sinomedia-page-spec/v1",
  "route": "/dash/data/posts",
  "title": "Bài viết & Video",
  "titleEn": "Posts & Videos",
  "priority": "P0",
  "minRole": "viewer",
  "layout": { "type": "dashboard", "sidebar": true, "header": true, "padding": "px-4 md:px-8 py-6", "maxWidth": "max-w-[1400px]" },
  "header": {
    "breadcrumb": ["SinoMedia", "Data Explorer", "Bài viết"],
    "title": "Bài viết & Video",
    "actions": [
      { "id": "export-btn", "label": "Xuất Excel/CSV", "type": "button", "variant": "outline", "icon": "ArrowDownTrayIcon", "role": "admin", "action": "export-posts" }
    ]
  },
  "filterBar": {
    "position": "top",
    "layout": "horizontal",
    "filterPayload": "json-to-backend",
    "filters": [
      { "id": "search", "type": "search-input", "placeholder": "Tìm theo nội dung, tiêu đề...", "fields": ["caption","title"] },
      { "id": "platform", "type": "multi-select-checkbox", "label": "Nền tảng", "field": "platform" },
      { "id": "tags", "type": "multi-select", "label": "Tags", "field": "tags", "loadFrom": "distinct:crawled_posts.tags" },
      { "id": "likes_min", "type": "number", "label": "Like tối thiểu", "field": "like_count", "operator": "gte" },
      { "id": "views_min", "type": "number", "label": "View tối thiểu", "field": "view_count", "operator": "gte" },
      { "id": "comments_min", "type": "number", "label": "Comment tối thiểu", "field": "comment_count", "operator": "gte" },
      { "id": "date_range", "type": "date-range-picker", "label": "Ngày đăng", "fields": { "from": "published_at_from", "to": "published_at_to" } },
      { "id": "crawled_date_range", "type": "date-range-picker", "label": "Ngày cào", "fields": { "from": "crawled_at_from", "to": "crawled_at_to" } }
    ]
  },
  "sections": [
    {
      "id": "posts-feed",
      "type": "post-grid-with-modal",
      "dataSource": {
        "table": "crawled_posts",
        "orderBy": [{ "field": "crawled_at", "direction": "DESC" }],
        "fields": ["id","platform","author_id","platform_uid","title","caption","cover_url","like_count","view_count","comment_count","media_urls","tags","published_at","crawled_at"]
      },
      "gridLayout": { "cols": { "default": 2, "md": 3, "lg": 4, "xl": 5 }, "gap": 4 },
      "card": {
        "coverImage": { "key": "cover_url", "source": "r2", "aspectRatio": "16/9" },
        "platformBadge": { "key": "platform", "position": "top-left" },
        "body": [
          { "key": "caption", "type": "text-truncate", "lines": 2, "fontSize": "text-xs" }
        ],
        "metrics": [
          { "key": "like_count", "icon": "HeartIcon", "format": "number-short" },
          { "key": "view_count", "icon": "EyeIcon", "format": "number-short" },
          { "key": "comment_count", "icon": "ChatBubbleIcon", "format": "number-short" }
        ],
        "tags": { "key": "tags", "maxDisplay": 2 },
        "adminActions": [
          { "id": "tag-post", "label": "Gắn nhãn", "icon": "TagIcon", "action": "open-tag-modal" },
          { "id": "delete-post", "label": "Xóa", "icon": "TrashIcon", "variant": "destructive", "action": "delete-post", "confirmText": "Xóa bài viết này?" }
        ]
      },
      "detailModal": {
        "layout": "split",
        "left": {
          "type": "media-player",
          "mediaKey": "media_urls",
          "source": "r2",
          "supportTypes": ["video", "image-slider"]
        },
        "right": {
          "sections": [
            { "type": "platform-author-header", "keys": ["platform", "author_id"] },
            { "type": "text-block", "key": "caption", "label": "Nội dung" },
            { "type": "metrics-row", "keys": ["like_count","view_count","comment_count","published_at"] },
            { "type": "tags-list", "key": "tags" },
            {
              "type": "comment-tree",
              "dataSource": { "table": "crawled_comments", "filterBy": "post_id", "orderBy": "like_count DESC" },
              "nestBy": "parent_cid",
              "maxDepth": 5,
              "columns": ["content", "like_count", "created_at"]
            }
          ]
        }
      },
      "emptyState": { "icon": "FilmIcon", "title": "Chưa có bài viết nào", "description": "Chạy task cào Search hoặc Creator để thu thập nội dung" },
      "pagination": { "pageSize": 40, "showTotal": true }
    }
  ]
}
