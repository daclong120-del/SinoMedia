{
  "$schema": "sinomedia-page-spec/v1",
  "route": "/dash/creative/calendar",
  "title": "Lịch tiếp thị",
  "titleEn": "Marketing Calendar",
  "priority": "P2",
  "minRole": "viewer",
  "layout": {
    "type": "dashboard",
    "sidebar": true,
    "header": true,
    "padding": "px-4 md:px-8 py-6",
    "maxWidth": "max-w-[1600px]"
  },
  "header": {
    "breadcrumb": ["SinoMedia", "Creative Hub", "Lịch tiếp thị"],
    "title": "Lịch tiếp thị",
    "titleEn": "Marketing Calendar",
    "actions": [
      {
        "id": "export-calendar",
        "label": "Xuất lịch",
        "labelEn": "Export Calendar",
        "type": "button",
        "variant": "outline",
        "icon": "ArrowDownTrayIcon",
        "action": "export-calendar-csv"
      }
    ]
  },
  "sections": [
    {
      "id": "calendar-controls",
      "type": "calendar-controls",
      "navigation": {
        "prevLabel": "◀",
        "nextLabel": "▶",
        "displayFormat": "Tháng {month}, {year}"
      },
      "viewSwitcher": {
        "options": [
          { "value": "month", "label": "Tháng", "default": true },
          { "value": "week", "label": "Tuần" }
        ]
      },
      "filters": [
        {
          "id": "platform",
          "type": "select",
          "label": "Nền tảng",
          "field": "platform",
          "allOption": true,
          "allLabel": "Tất cả nền tảng",
          "options": [
            { "value": "douyin", "label": "Douyin" },
            { "value": "kuaishou", "label": "Kuaishou" },
            { "value": "xhs", "label": "XHS" },
            { "value": "bilibili", "label": "Bilibili" },
            { "value": "weibo", "label": "Weibo" },
            { "value": "zhihu", "label": "Zhihu" },
            { "value": "tieba", "label": "Tieba" },
            { "value": "tiktok", "label": "TikTok" }
          ]
        },
        {
          "id": "advertiser",
          "type": "search-select",
          "label": "Advertiser",
          "field": "author_id",
          "loadFrom": "crawled_authors",
          "displayField": "nickname",
          "placeholder": "Tìm advertiser..."
        }
      ]
    },
    {
      "id": "calendar-grid",
      "type": "calendar-month-grid",
      "description": "Calendar grid — mỗi ô ngày hiện số creative + thumbnails nhỏ",
      "dataSource": {
        "endpoint": "GET /functions/creative-calendar",
        "groupBy": "DATE(published_at)",
        "fields": ["date", "count", "top_creatives"]
      },
      "dayCell": {
        "showCount": true,
        "countLabel": "{count} creative",
        "maxThumbnails": 2,
        "thumbnailSize": 32,
        "thumbnailKey": "top_creatives.cover_url",
        "highlightToday": true,
        "todayColor": "primary"
      },
      "dayHeaders": {
        "vi": ["T2", "T3", "T4", "T5", "T6", "T7", "CN"],
        "en": ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"]
      },
      "dayClickAction": {
        "type": "open-drawer",
        "drawerId": "day-detail-drawer"
      }
    },
    {
      "id": "day-detail-drawer",
      "type": "slide-drawer",
      "position": "right",
      "width": 400,
      "title": "Creative ngày {date}",
      "titleEn": "Creatives on {date}",
      "content": {
        "type": "creative-card-list",
        "dataSource": {
          "table": "crawled_posts",
          "filterBy": "DATE(published_at) = :selectedDate",
          "orderBy": [{ "field": "view_count", "direction": "DESC" }],
          "fields": ["id", "platform", "caption", "cover_url", "view_count", "like_count", "published_at"]
        },
        "card": {
          "layout": "horizontal",
          "coverImage": { "key": "cover_url", "source": "r2", "width": 64, "height": 64 },
          "platformBadge": { "key": "platform" },
          "body": [
            { "key": "caption", "type": "text-truncate", "lines": 1 }
          ],
          "metrics": [
            { "key": "view_count", "icon": "EyeIcon", "format": "number-short" },
            { "key": "like_count", "icon": "HeartIcon", "format": "number-short" }
          ],
          "clickAction": { "navigate": "/dash/creative/{id}" }
        },
        "emptyState": {
          "title": "Không có creative nào trong ngày này"
        }
      }
    }
  ]
}
