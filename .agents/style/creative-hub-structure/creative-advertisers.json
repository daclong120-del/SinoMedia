{
  "$schema": "sinomedia-page-spec/v1",
  "route": "/dash/creative/advertisers",
  "title": "Phân tích Advertiser",
  "titleEn": "Advertiser Analysis",
  "priority": "P1",
  "minRole": "viewer",
  "layout": {
    "type": "dashboard",
    "sidebar": true,
    "header": true,
    "padding": "px-4 md:px-8 py-6",
    "maxWidth": "max-w-[1400px]"
  },
  "header": {
    "breadcrumb": ["SinoMedia", "Creative Hub", "Phân tích Advertiser"],
    "title": "Phân tích Advertiser",
    "titleEn": "Advertiser Analysis",
    "actions": [
      {
        "id": "export-btn",
        "label": "Xuất danh sách",
        "labelEn": "Export List",
        "type": "button",
        "variant": "outline",
        "icon": "ArrowDownTrayIcon",
        "action": "export-advertisers"
      }
    ]
  },
  "filterBar": {
    "position": "top",
    "layout": "horizontal",
    "filterPayload": "json-to-backend",
    "filters": [
      {
        "id": "search",
        "type": "search-input",
        "placeholder": "Tìm theo tên advertiser...",
        "placeholderEn": "Search by advertiser name...",
        "fields": ["nickname"]
      },
      {
        "id": "platform",
        "type": "multi-select-checkbox",
        "label": "Nền tảng",
        "field": "platform",
        "options": ["douyin", "xhs", "bilibili", "weibo", "kuaishou", "tieba", "zhihu", "tiktok"]
      },
      {
        "id": "sort_by",
        "type": "select",
        "label": "Sắp xếp",
        "field": "sort_by",
        "options": [
          { "value": "creative_count_desc", "label": "Số creative nhiều nhất" },
          { "value": "total_views_desc", "label": "Tổng views cao nhất" },
          { "value": "last_active_desc", "label": "Hoạt động gần đây nhất" }
        ],
        "defaultValue": "creative_count_desc"
      }
    ]
  },
  "sections": [
    {
      "id": "advertisers-table",
      "type": "data-table-with-filters",
      "dataSource": {
        "endpoint": "GET /functions/creative-advertisers",
        "fields": ["id", "nickname", "platform", "avatar_url", "creative_count", "total_views", "total_likes", "last_active_at"]
      },
      "columns": [
        { "key": "avatar_url", "label": "", "type": "avatar", "width": 40, "source": "r2" },
        { "key": "nickname", "label": "Tên Advertiser", "labelEn": "Advertiser Name", "type": "text-bold", "linkTo": "/dash/creative/advertisers/{id}" },
        {
          "key": "platform",
          "label": "Nền tảng",
          "labelEn": "Platforms",
          "type": "platform-badge-list",
          "width": 120
        },
        { "key": "creative_count", "label": "Số Creative", "labelEn": "Creatives", "type": "number-formatted", "width": 110, "sortable": true },
        { "key": "total_views", "label": "Tổng Views", "labelEn": "Total Views", "type": "number-formatted", "width": 120, "sortable": true },
        { "key": "total_likes", "label": "Tổng Likes", "labelEn": "Total Likes", "type": "number-formatted", "width": 110, "sortable": true },
        { "key": "last_active_at", "label": "Hoạt động cuối", "labelEn": "Last Active", "type": "relative-time", "width": 130 },
        {
          "key": "actions",
          "label": "",
          "type": "action-menu",
          "width": 60,
          "actions": [
            { "id": "view-profile", "label": "Xem hồ sơ", "labelEn": "View Profile", "icon": "UserIcon", "action": "navigate", "href": "/dash/creative/advertisers/{id}" },
            { "id": "view-creatives", "label": "Xem creative", "labelEn": "View Creatives", "icon": "PhotoIcon", "action": "navigate", "href": "/dash/creative/search?author_id={id}" }
          ]
        }
      ],
      "rowClick": { "action": "navigate", "href": "/dash/creative/advertisers/{id}" },
      "emptyState": {
        "icon": "UsersIcon",
        "title": "Chưa có dữ liệu advertiser",
        "description": "Dữ liệu advertiser sẽ hiển thị khi crawler thu thập được creative từ các nền tảng"
      },
      "pagination": { "pageSize": 30, "showTotal": true }
    }
  ]
}
